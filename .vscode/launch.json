{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Agent Demo (development)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/agent-demo",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "APP_ENV": "development"
      },
      "showLog": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Agent Demo (staging)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/agent-demo",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "APP_ENV": "staging"
      },
      "showLog": true,
      "console": "integratedTerminal"
    }
  ]
}
