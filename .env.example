# DeepSeek（必填）
# 注意：修改 .env 后重新运行 go run 即可，无需 export
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 调试日志（设为 1 开启，输出到终端）
# AGENT_DEBUG=1   # Agent 执行步骤
# LLM_DEBUG=1     # 每次请求大模型的完整 JSON（与 AGENT_DEBUG 二选一或同时开）

# MySQL 对话持久化（可选，不填则仅用内存记忆）
# 先创建数据库: CREATE DATABASE go_agent CHARACTER SET utf8mb4;
# MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/go_agent?parseTime=true&charset=utf8mb4&loc=Local
