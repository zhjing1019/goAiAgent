# ========== 环境隔离 ==========
# APP_ENV 决定加载哪个环境文件（默认 development）
#   development → .env + .env.development + .env.development.local
#   staging     → .env + .env.staging     + .env.staging.local
#   production  → 不加载 .env，仅用系统/容器环境变量
#
# 初始化开发环境:  bash scripts/init-env.sh development
# 启动:            make run-dev  |  make run-staging  |  make run-prod
APP_ENV=development

# DeepSeek（必填）
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 调试日志（设为 1 开启，输出到终端）
# AGENT_DEBUG=1   # Agent 执行步骤
# LLM_DEBUG=1     # 每次请求大模型的完整 JSON

# MySQL 对话持久化（可选，不填则仅用内存记忆）
# 开发库建议: go_agent_dev  |  预发: go_agent_staging  |  生产: go_agent_prod
# MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/go_agent_dev?parseTime=true&charset=utf8mb4&loc=Local

# Milvus 向量知识库 RAG（可选，第 6 步）
# MILVUS_ADDR=127.0.0.1:19530
# MILVUS_COLLECTION=go_agent_kb_dev
# MILVUS_TOKEN=

# Embedding 向量化（RAG 必填，需 OpenAI 兼容 /embeddings 接口）
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# HTTP API（第 8 步，agent-server 使用）
# HTTP_ADDR=:8080

# Redis（可选，会话缓存 + HTTP 限流）
# REDIS_ADDR=127.0.0.1:6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_SESSION_TTL=24h          # 会话消息缓存过期时间（需同时配 MySQL）
# REDIS_RATE_LIMIT=60            # /api/chat 每 IP 每分钟上限，0=不限流
