# 开发环境 — 复制到项目根目录: cp config/env/development.env.example .env.development
# 启动: make run-dev  或  APP_ENV=development go run ./cmd/agent-demo

APP_ENV=development
APP_NAME=goAiAgent

# DeepSeek
DEEPSEEK_API_KEY=your_dev_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 日志级别：debug / info / warn / error（结构化 JSON 输出到 stdout）
LOG_LEVEL=info

# MySQL（开发库，与 staging/prod 隔离）
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/go_agent_dev?parseTime=true&charset=utf8mb4&loc=Local

# Milvus（可选）
# MILVUS_ADDR=127.0.0.1:19530
# MILVUS_COLLECTION=go_agent_kb_dev
# MILVUS_TOKEN=

# Embedding（RAG 可选）
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# Redis（可选，配合 MySQL 做会话缓存 + HTTP 限流）
# REDIS_ADDR=127.0.0.1:6379
# REDIS_SESSION_TTL=24h
# REDIS_RATE_LIMIT=60
