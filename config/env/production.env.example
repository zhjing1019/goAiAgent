# 生产环境 — 仅作文档参考，生产环境禁止加载 .env 文件！
# 所有变量通过 K8s Secret / 云平台环境变量 / CI 注入。
#
# 必需:
#   APP_ENV=production
#   DEEPSEEK_API_KEY=...
#   MYSQL_DSN=...（库名建议 go_agent_prod）
#
# 可选:
#   MILVUS_ADDR=...
#   EMBEDDING_API_KEY=...

APP_ENV=production
APP_NAME=goAiAgent

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

AGENT_DEBUG=0
LLM_DEBUG=0

# MYSQL_DSN=user:pass@tcp(prod-mysql:3306)/go_agent_prod?parseTime=true&charset=utf8mb4&loc=Local
