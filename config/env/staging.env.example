# 预发环境 — 复制到项目根目录: cp config/env/staging.env.example .env.staging
# 启动: make run-staging  或  APP_ENV=staging go run ./cmd/agent-demo

APP_ENV=staging
APP_NAME=goAiAgent

DEEPSEEK_API_KEY=your_staging_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 预发关闭详细调试
AGENT_DEBUG=0
LLM_DEBUG=0

MYSQL_DSN=root:password@tcp(staging-mysql.internal:3306)/go_agent_staging?parseTime=true&charset=utf8mb4&loc=Local

# MILVUS_ADDR=staging-milvus.internal:19530
# MILVUS_COLLECTION=go_agent_kb_staging
